# --- 資料庫 ---
# 留空 = 走本地 SQLite 檔（data/blackcat.db），零雲端設定即可開發。
# 要跨裝置同步時（階段 1）再填 Turso 雲端認證。
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- TTS spike 憑證（階段 3 前置驗證；複製本檔成 .env.local 後填值）---
# 三支 spike 都會自動讀 .env.local：npm run spike:tts:azure / :iqt / :eleven
# 留空 = spike 友善退出（不真打）；填值才會實際呼叫 API。

# Azure Speech（komaTTS resource）：Portal → komaTTS → Keys and Endpoint
AZURE_TTS_KEY=
AZURE_TTS_REGION=        # 例 eastasia / japaneast / eastus

# 自家 IQT TTS（最高槓桿驗證；拿到 endpoint+認證後填）
IQT_TTS_ENDPOINT=
IQT_TTS_KEY=

# ElevenLabs（備選音源）：後台 → Profile → API Key
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=     # 可選，未填用預設多語音色

# --- 權限 / 額度（上線必設）---
# session cookie 的 HMAC 簽章金鑰。上線必填(至少 16 字元),否則 production 啟動即丟錯。
# 產一把：openssl rand -base64 32
SESSION_SECRET=
# admin 邀請碼(逗號分隔,無限額度)。你或你授權的人拿到即 admin。
ADMIN_CODES=
# 推薦碼(逗號分隔,明碼)→ 命中即 member、會員額度。好記、可公開分享(不入庫)。
REFERRAL_CODES=
# 每日合成額度(只計實際合成,快取重播免費)。留空用預設 member=30 / guest=5。
TTS_QUOTA_MEMBER=30
TTS_QUOTA_GUEST=5
# member 碼用 `npm run code:gen -- "備註"` 產生(存 DB,只存 sha256)。

# --- better-auth：Email OTP 登入（與上面邀請碼系統並存）---
# better-auth session 簽章金鑰。上線必填(≥32 字元)。產一把：openssl rand -base64 32
BETTER_AUTH_SECRET=
# 站台對外 URL（含 protocol）。dev 用 http://localhost:3000;prod 填正式網域。
BETTER_AUTH_URL=http://localhost:3000
# admin email 允許清單(逗號分隔)→ 以這些 email 登入即 admin、無限額度。其餘 email = member。
ADMIN_EMAILS=
# Resend 寄送 OTP 信。留空 = dev 模式把 OTP 印到 server console（不真寄）。
# prod 必填 + 須先在 Resend 驗證 EMAIL_FROM 的寄件網域。
RESEND_API_KEY=
EMAIL_FROM="Koma <login@yourdomain.com>"
